{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true
  },
  "include": [
    "src/**/*.ts",
    "capture.ts",
    "server.ts",
    "dashboard-web/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "output",
    "dashboard-web/index.html"
  ]
}
