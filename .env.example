PORT=3001

# How often (minutes) to regenerate the dashboard image
REFRESH_INTERVAL_MINUTES=15

# Quiet hours: skip scheduled generation between these hours (local time, 0–23)
# If unset, generation runs around the clock.
# Example: skip 01:00–05:59 → QUIET_HOURS_START=1 QUIET_HOURS_END=6
# QUIET_HOURS_START=1
# QUIET_HOURS_END=6

# Per-source cache TTL (optional, shown with defaults)
# WEATHER_REFRESH_MINUTES=15
# CALENDAR_REFRESH_MINUTES=15
# LUNCH_REFRESH_HOURS=24
# INDOOR_REFRESH_MINUTES=15

# How long to wait before retrying a failed data source (optional)
# ERROR_RETRY_MINUTES=2

# Weather: coordinates for Open-Meteo (api.open-meteo.com) — free, no API key needed
OPEN_METEO_LAT=56.2
OPEN_METEO_LON=12.56

N8N_WEBHOOK_CALENDAR=https://n8nflow.duckdns.org/webhook/<calendar-id>
N8N_WEBHOOK_LUNCH=https://n8nflow.duckdns.org/webhook/6e6ed191-a7c2-44ba-8193-1460fffd9ccb
N8N_WEBHOOK_INDOOR=https://n8nflow.duckdns.org/webhook/<indoor-id>

HOMEY_IP=192.168.x.x
HOMEY_TOKEN=
HOMEY_USERNAME=
HOMEY_PASSWORD=

BROWSERLESS_TOKEN=
